{
  "name": "aria2-streamer",
  "version": "1.0.0",
  "description": "Aria2 Streamer Pro",
  "main": "main.js",
  "scripts": {
    "dev": "node server.js",
    "start": "electron .",
    "pack": "electron-builder"
  },
  "build": {
    "appId": "com.aria2streamer.app",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "extraResources": [
      {
        "from": "bin/aria2c",
        "to": "aria2c",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "main.js",
      "server.js",
      "public/**/*",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}
