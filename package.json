{
  "name": "downstream",
  "productName": "DownStream",
  "version": "1.0.0",
  "description": "DownStream — a download manager with streaming support",
  "main": "backend/main.js",
  "scripts": {
    "dev": "node backend/server.js",
    "start": "electron .",
    "pack": "electron-builder",
    "build": "echo 'No separate build step required (static frontend)'"
  },
  "build": {
    "appId": "com.downstream.app",
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "extraResources": [
      {
        "from": "bin/aria2c",
        "to": "aria2c",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "backend/**/*",
      "frontend/**/*",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.8.1"
  }
}
